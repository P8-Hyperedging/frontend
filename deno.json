{
  "tasks": {
    "dev": "deno run --watch --env-file=.env --allow-env --allow-read --allow-net main.ts & npx @tailwindcss/cli -i public/css/input.css -o public/css/output.css --watch"
  },
  "lint": {
    "include": ["templates/", "services/", "./"],
    "exclude": [],
    "rules": {
      "tags": ["recommended"],
      "include": ["no-console", "no-commented-code"],
      "exclude": [""]
    }
  },
  "imports": {
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@deno-library/logger": "jsr:@deno-library/logger@^1.2.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/http": "jsr:@std/http@^1.0.25"
  },
  "allowScripts": {
    "allow": [],
    "deny": ["npm:@parcel/watcher@2.5.6"]
  }
}
